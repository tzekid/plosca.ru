#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN="$ROOT/target/release/nob"

if [[ ! -x "$BIN" ]]; then
  cargo build --release --bin nob --manifest-path "$ROOT/Cargo.toml"
else
  for path in "$ROOT/Cargo.toml" "$ROOT/Cargo.lock" "$ROOT/src/bin/nob.rs"; do
    if [[ "$path" -nt "$BIN" ]]; then
      cargo build --release --bin nob --manifest-path "$ROOT/Cargo.toml"
      break
    fi
  done
fi

exec "$BIN" "$@"
